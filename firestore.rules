rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidDashboard(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.collaborators is list &&
             data.layout is map;
    }

    match /dashboards/{dashboardId} {
      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        (request.auth.token.email != null && request.auth.token.email in resource.data.collaborators)
      );
      allow get: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        (request.auth.token.email != null && request.auth.token.email in resource.data.collaborators)
      );
      allow create: if isSignedIn() && 
                    incoming().ownerId == request.auth.uid &&
                    isValidDashboard(incoming());
      allow update: if isSignedIn() && (
                      resource.data.ownerId == request.auth.uid || 
                      (request.auth.token.email != null && request.auth.token.email in resource.data.collaborators)
                    ) &&
                    isValidDashboard(incoming()) &&
                    incoming().ownerId == existing().ownerId; // Immutable owner
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      match /dashboards/{dId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /test/connection {
      allow get: if true;
    }
  }
}
